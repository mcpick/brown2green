---
import Section from "@/components/ui/Section.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import { agents } from "@/lib/data";
---

<Section id="agents" bg="surface" width="lg">
  <SectionHeader subtitle="Agents" />
  <h2 class="mb-4 font-display text-3xl tracking-tight md:text-4xl">
    Specialised agents. Lean&nbsp;context.
  </h2>
  <p class="mb-16 max-w-lg text-lg text-ink-muted">
    One agent per job. Each gets only the context it needs — not your entire&nbsp;codebase.
  </p>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {agents.map((a) => (
      <div class="rounded-2xl border border-border bg-white p-5 transition-all hover:shadow-md hover:border-green/30">
        <span class="mb-3 inline-block rounded-full bg-green-light px-2.5 py-0.5 font-mono text-[10px] font-bold uppercase text-green">{a.role}</span>
        <h3 class="mb-1 font-mono text-sm font-bold">@{a.name}</h3>
        <p class="mb-3 text-xs leading-relaxed text-ink-muted">{a.desc}</p>
        <code class="block rounded-lg bg-surface-alt px-3 py-2 font-mono text-[11px] text-ink-faint">{a.usage}</code>
      </div>
    ))}
  </div>
</Section>
