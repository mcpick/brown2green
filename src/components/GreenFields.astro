---
import ParallaxLayer from "@/components/ui/ParallaxLayer.astro";
---

<ParallaxLayer image="/images/green-fields.png" minHeight="min-h-[50vh]">
  <div class="absolute inset-0 bg-gradient-to-b from-white/70 via-transparent to-ink/80"></div>
  <div class="relative z-10 flex min-h-[50vh] items-center justify-center px-4 sm:px-6">
    <h2 class="text-center font-display text-4xl tracking-tight text-white drop-shadow-lg md:text-5xl">
      The grass gets greener<br />with every commit. <span class="text-green-soft">🌱</span>
    </h2>
  </div>
</ParallaxLayer>
