---
import { cn } from "@/lib/cn";

interface Props {
  id?: string;
  bg?: "white" | "surface" | "ink";
  width?: "md" | "lg" | "xl";
  class?: string;
}

const {
  id,
  bg = "white",
  width = "lg",
  class: className,
} = Astro.props;

const bgMap = {
  white: "bg-white",
  surface: "bg-surface",
  ink: "bg-ink text-white",
} as const;

const widthMap = {
  md: "max-w-3xl",
  lg: "max-w-4xl",
  xl: "max-w-5xl",
} as const;
---

<section
  id={id}
  class={cn("relative z-10 px-4 py-28 sm:px-6", bgMap[bg], className)}
>
  <div class={cn("mx-auto", widthMap[width])}>
    <slot />
  </div>
</section>
