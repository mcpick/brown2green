---
import { cn } from "@/lib/cn";

interface Props {
  subtitle: string;
  subtitleColor?: "brown" | "green" | "white";
  class?: string;
}

const {
  subtitle,
  subtitleColor = "green",
  class: className,
} = Astro.props;

const colorMap = {
  brown: "text-brown",
  green: "text-green",
  white: "text-white/40",
} as const;
---

<p class={cn("mb-3 font-mono text-xs uppercase tracking-[0.3em]", colorMap[subtitleColor], className)}>
  {subtitle}
</p>
<slot />
