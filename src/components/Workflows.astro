---
import Section from "@/components/ui/Section.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import { simpleSteps, complexSteps } from "@/lib/data";
---

<Section id="workflows" bg="white" width="lg">
  <SectionHeader subtitle="Workflows" />
  <h2 class="mb-4 font-display text-3xl tracking-tight md:text-4xl">
    Two paths. Same quality&nbsp;bar.
  </h2>
  <p class="mb-16 max-w-lg text-lg text-ink-muted">
    Simple features are fast. Complex features get the full treatment. Both end with&nbsp;documentation.
  </p>

  <div class="grid gap-8 lg:grid-cols-2">
    <!-- Simple -->
    <div class="rounded-2xl border border-border bg-surface p-6 sm:p-8">
      <span class="mb-4 inline-block rounded-full bg-green-light px-4 py-1 font-mono text-xs font-bold text-green">SIMPLE</span>
      <h3 class="mb-1 font-display text-xl">1–3 files</h3>
      <p class="mb-6 text-sm text-ink-muted">Well-understood area, contained&nbsp;changes</p>
      <div class="space-y-3">
        {simpleSteps.map((s) => (
          <div class="flex items-center gap-3">
            <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-green/10 font-mono text-xs font-bold text-green">{s.num}</span>
            <span class="text-sm font-medium">{s.title}</span>
            <span class="ml-auto font-mono text-xs text-ink-faint">{s.cmd}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Complex -->
    <div class="rounded-2xl border border-ink/10 bg-ink/[0.03] p-6 shadow-sm sm:p-8">
      <span class="mb-4 inline-block rounded-full bg-ink px-4 py-1 font-mono text-xs font-bold text-white">COMPLEX</span>
      <h3 class="mb-1 font-display text-xl">Multi-layer feature</h3>
      <p class="mb-6 text-sm text-ink-muted">Multiple files, layers, and&nbsp;dependencies</p>
      <div class="space-y-3">
        {complexSteps.map((s) => (
          <div class="flex items-center gap-3">
            <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-ink font-mono text-xs font-bold text-white">{s.num}</span>
            <span class="text-sm font-medium">{s.title}</span>
            <span class="ml-auto font-mono text-xs text-ink-faint">@{s.agent}</span>
          </div>
        ))}
      </div>
      <p class="mt-6 rounded-xl bg-green-light px-4 py-3 text-xs text-ink-muted">
        💡 Some steps take many iterations. The planner raises questions. The reviewer flags blockers. That's the system&nbsp;working.
      </p>
    </div>
  </div>
</Section>
